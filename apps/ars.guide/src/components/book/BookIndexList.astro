---
import type { SidebarEntry } from "../../utils/sidebar";

interface Props {
  entries: SidebarEntry[];
}

const { entries } = Astro.props;
---

<ul>
  {entries.map(entry => (
    <li>
      <a href={entry.href}>{entry.title}</a>
      {entry.children?.length ? <Astro.self entries={entry.children} /> : null}
    </li>
  ))}
</ul>
