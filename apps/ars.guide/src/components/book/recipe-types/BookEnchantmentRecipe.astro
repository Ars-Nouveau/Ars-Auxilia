---
import { Image } from "astro:assets";
import { getItemRenderUrl } from "@ars/addon-builder";
import { getItemTooltip } from "../../../utils/book-pages";
import {
  asRecipeRecordArray,
  asPedestalCells,
  type BookRecipeRecord,
} from "../../../utils/book-recipes";
import BookRecipeIngredient from "../BookRecipeIngredient.astro";

interface Props {
  recipe: BookRecipeRecord;
  recipeId: string;
  langByKey?: Map<string, string>;
}

const { recipe, langByKey } = Astro.props;
const pedestalItems = asRecipeRecordArray(recipe.pedestalItems);
const enchantment =
  typeof recipe.enchantment === "string" ? recipe.enchantment : undefined;
const level = typeof recipe.level === "number" ? recipe.level : undefined;
const resultLabel = enchantment
  ? `${getItemTooltip(enchantment, langByKey)}${level ? ` ${level}` : ""}`
  : undefined;
const apparatusCells = asPedestalCells(undefined, pedestalItems);

---

<div class="book-recipe__flow">
  <div class="book-recipe-grid book-recipe-grid--apparatus" aria-label="Enchanting apparatus grid">
    {apparatusCells.map((ingredient, index) => (
      index === 4 ? (
        <span class="book-recipe-ingredient book-recipe-ingredient--slot book-recipe-ingredient--reagent" title="Item to be Enchanted" data-bs-toggle="tooltip" data-bs-title="Item to be Enchanted" data-bs-placement="bottom">
          <span class="book-recipe-ingredient__slot-icon" aria-label="Item to be Enchanted">?</span>
        </span>
      ) : (
        <BookRecipeIngredient
          ingredient={ingredient}
          label={`Pedestal ${index < 4 ? index + 1 : index}`}
          langByKey={langByKey}
        />
      )
    ))}
  </div>
  {resultLabel && (
    <>
      <span class="book-recipe__arrow" aria-hidden="true">→</span>
      <span class="book-recipe-ingredient" title={resultLabel}>
        <Image
          data-bs-toggle="tooltip"
          data-bs-title={resultLabel}
          data-bs-placement="bottom"
          class="book-icon__image glyph"
          src={getItemRenderUrl("minecraft:enchanted_book")!}
          alt="Enchanted Book"
          title={resultLabel}
          width={128}
          height={128}
          loading="lazy"
        />
      </span>
    </>
  )}
</div>
