---
import {
  asRecipeRecord,
  asRecipeRecordArray,
  type BookRecipeRecord,
} from "../../../utils/book-recipes";
import BookPedestalRecipeLayout from "../BookPedestalRecipeLayout.astro";
import BookRecipeIngredient from "../BookRecipeIngredient.astro";

interface Props {
  recipe: BookRecipeRecord;
  langByKey?: Map<string, string>;
}

const { recipe, langByKey } = Astro.props;
const input = asRecipeRecord(recipe.input);
const pedestalItems = asRecipeRecordArray(recipe.pedestalItems);
const result = asRecipeRecord(recipe.result) ?? asRecipeRecord(recipe.output);
---

<BookPedestalRecipeLayout
  ariaLabel="Imbuement grid"
  pedestalItems={pedestalItems}
  langByKey={langByKey}
>
  <BookRecipeIngredient
    slot="center"
    ingredient={input}
    label="Input"
    variant="reagent"
    langByKey={langByKey}
  />
  <BookRecipeIngredient
    slot="result"
    ingredient={result}
    label="Result"
    langByKey={langByKey}
  />
</BookPedestalRecipeLayout>
