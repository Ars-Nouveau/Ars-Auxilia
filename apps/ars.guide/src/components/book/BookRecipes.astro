---
import type { BookPageRecipeData } from "../../utils/book-pages";
import BookRecipe from "./BookRecipe.astro";

interface Props {
  recipes: BookPageRecipeData[];
  langByKey?: Map<string, string>;
}

const { recipes, langByKey } = Astro.props;
---

{recipes.length > 0 && (
    <div class="book-recipes">
      {recipes.map(recipe => <BookRecipe recipe={recipe} langByKey={langByKey} />)}
    </div>
)}
