---
import type { BookPageItemData } from "../../utils/book-pages";
import BookIcon from "./BookIcon.astro";

interface Props {
  items: BookPageItemData[];
  langByKey?: Map<string, string>;
}

const { items, langByKey } = Astro.props;
---

{items.length > 0 && (
  <ul class="book-items" aria-label="Items">
    {items.map(item => (
      <li class="book-items__item">
        <BookIcon icon={item.item} iconUrl={item.iconUrl} langByKey={langByKey} />
      </li>
    ))}
  </ul>
)}

<style>
  .book-items {
    list-style-type: none;
  }
</style>