---
import { getCollection } from "astro:content";
import { IconArrowLeft, IconArrowRight, IconPencil } from "@tabler/icons-react";
import banner from "../../assets/banner.gif";
import Seo from "../components/layout/Seo.astro";
import Heading from "../components/navigation/Heading.astro";
import Sidebar from "../components/navigation/Sidebar.astro";
import VersionSelect from "../components/navigation/VersionSelect.astro";
import { getBookNamespaces } from "../utils/book";
import { editLink } from "../utils/constants";
import {
  getNextEntry,
  getPreviousEntry,
  type ParentHeading,
  type Sidebar as TSidebar,
} from "../utils/sidebar";
import { toTitleCase } from "../utils/text";
import {
  getLatestVersion,
  isVersionedCollection,
  type Version,
} from "../utils/versions";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  sidebar: TSidebar;
  headings?: ParentHeading[];
  title: string;
  description: string;
  path: string;
  collection: string;
  slug: string;
  editPath?: string;
  version?: Version;
  hasContent?: boolean;
  aliases?: string;
}

const {
  collection,
  slug,
  headings: formattedHeadings = [],
  sidebar,
  title,
  description,
  path,
  editPath,
  version,
  hasContent = true,
  aliases,
} = Astro.props;

const latestVersion = await getLatestVersion();
const prev = getPreviousEntry(slug, sidebar);
const next = getNextEntry(slug, sidebar);
const showVersionSelect = version && isVersionedCollection(collection);
const showOlderVersionBanner = showVersionSelect && version !== latestVersion;
const sidebarSection = sidebar.find((section) => section.active)?.title;

let namespacesJson: string | undefined;
if (collection === "book") {
  const presentIds = getBookNamespaces(sidebar);
  const projects = await getCollection("projects");
  const projectById = new Map(projects.map((p) => [p.id, p.data]));
  if (presentIds.length > 1) {
    const pinnedIds = new Set(["ars_nouveau", "minecraft"]);
    const filtered = presentIds
      .filter((id) => !pinnedIds.has(id) || projectById.has(id))
      .map((id) => {
        const project = projectById.get(id);
        return {
          id,
          text: project?.display_name ?? toTitleCase(id),
          color: project?.color ?? "#888888",
          pinned: pinnedIds.has(id),
        };
      })
      .sort((a, b) => a.text.localeCompare(b.text));
    namespacesJson = JSON.stringify(filtered);
  }
}
---

<BaseLayout layout="section docs" sidebar={sidebar} collection={collection} namespacesJson={namespacesJson}>
  <Fragment slot="head">
    <Seo title={title} description={description} path={path} />
  </Fragment>
    <div class="wrap container-lg" role="document">
        <div class="content">
            <div class="row flex-xl-nowrap">
                <div class="col-lg-5 col-xl-4 docs-sidebar d-none d-lg-block">
                    <div class="starbuncle-petition-banner" data-pagefind-ignore="all">
                      <a href="https://www.makeship.com/petitions/starbuncle" class="starbuncle-petition-link" target="_blank" rel="noopener noreferrer">
                        <span class="starbuncle-petition-img" role="img" aria-label="Starbuncle Plush"></span>
                        <span class="starbuncle-petition-text">
                          <strong>Order a Starbuncle&nbsp;Plush from Makeship!</strong>
                        </span>
                      </a>
                    </div>
                    <nav class="docs-links" aria-label="Main navigation">
                        <Sidebar sidebar={sidebar} collection={collection} namespaces={namespacesJson}>
                    </nav>
                </div>
                <nav class="docs-toc d-none d-xl-block col-xl-3" aria-label="Secondary navigation">
                  <div class="page-links">
                    {formattedHeadings.length > 0 && <>
                      <h3>On this page</h3>
                      <nav id="toc">
                        <ul>
                          {formattedHeadings.map(heading => <Heading heading={heading} />)}
                        </ul>
                      </nav>
                    </>}
                  </div>
                </nav>
                <main class="docs-content col-lg-11 col-xl-9" {...hasContent && {"data-pagefind-body": ""}} {...hasContent && collection === "book" && {"data-pagefind-weight": "8"}} {...hasContent && {"data-pagefind-filter": `category:${collection}`}}>
                    {hasContent && version && <data value={version} data-pagefind-filter={`version:${version}`}></data>}
                    {hasContent && aliases && <data value={aliases} data-pagefind-meta={`aliases:${aliases}`}></data>}
                    {hasContent && sidebarSection && <data value={sidebarSection} data-pagefind-meta={`section:${sidebarSection}`} data-pagefind-weight="7">{sidebarSection}</data>}
                    <div class="docs-banner-callout" data-pagefind-ignore="all">
                      <a href="https://jarva.bloom.host/" class="docs-banner-link" target="_blank" rel="noopener noreferrer">
                        <img src={banner.src} alt="Bloom Host" class="docs-banner" />
                        <span class="docs-banner-text">Use code <strong>Jarva</strong> for 25% off your first invoice</span>
                      </a>
                    </div>
                    <div class="docs-title-bar">
                      <h1 data-pagefind-meta="title">{title}</h1>
                      {showVersionSelect && <VersionSelect version={version} collection={collection} slug={slug} />}
                    </div>
                    {showOlderVersionBanner && (
                      <aside class="alert alert-warning older-version-banner" role="note" data-pagefind-ignore="all">
                        <strong>Older version.</strong> This content is for {version}. Current content is for {latestVersion}.
                      </aside>
                    )}
                    {formattedHeadings.length > 0 && <nav class="toc-mobile d-xl-none" aria-label="Quaternary navigation">
                      <details>
                        <summary>
                          On this page
                        </summary>
                        <div class="page-links">
                          <nav id="TableOfContents">
                            <ul>
                              {formattedHeadings.map(heading => <Heading heading={heading} />)}
                            </ul>
                          </nav>
                        </div>
                      </details>
                    </nav>}
                    <slot />
                    {editPath && <div data-pagefind-ignore="all" class="page-footer-meta d-flex flex-column flex-md-row justify-content-between">
                        <div class="edit-page">
                            <a href={`${editLink}/${editPath}`}>
                                <IconPencil size={16} />
                                Edit this page on GitHub
                            </a>
                        </div>
                    </div>}
                    <div data-pagefind-ignore="all" class="page-nav d-flex flex-column flex-sm-row">
                      {prev != null && <div class="card w-100">
                        <div class="card-body d-flex">
                          <div class="d-flex flex-column justify-content-center">
                            <IconArrowLeft size={20} />
                          </div>
                          <div class="d-flex flex-column">
                            <div class="text-body-secondary">Prev</div>
                            <a href={prev.href} class="stretched-link text-reset text-decoration-none">{prev.title}</a>
                          </div>
                        </div>
                      </div>}
                      {prev != null && next != null && <div class="m-2"></div>}
                      {next != null && <div class="card text-end w-100">
                        <div class="card-body d-flex justify-content-end">
                          <div class="d-flex flex-column">
                            <div class="text-body-secondary">Next</div>
                            <a href={next.href} class="stretched-link text-reset text-decoration-none">{next.title}</a>
                          </div>
                          <div class="d-flex flex-column justify-content-center">
                            <IconArrowRight size={20} />
                          </div>
                        </div>
                      </div>}
                    </div>
                </main>
            </div>
        </div>
    </div>
</BaseLayout>

<style is:global>
  .docs-content data {
    display: none;
  }

  .starbuncle-petition-banner {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .offcanvas-body .starbuncle-petition-banner {
    margin-top: 0;
    margin-bottom: 0;
  }

  .starbuncle-petition-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1rem;
    background: linear-gradient(135deg, #1a0d2e 0%, #2d1060 100%);
    border: 1px solid #9b59b6;
    border-radius: 6px;
    text-decoration: none;
    color: #f0e6ff;
    transition: border-color 0.2s, background 0.2s;
  }

  .starbuncle-petition-link:hover {
    border-color: #c39bd3;
    background: linear-gradient(135deg, #221040 0%, #3b1580 100%);
    text-decoration: none;
    color: #fff;
  }

  .starbuncle-petition-img {
    flex: 0 0 auto;
    height: 4.5rem;
    width: 4.5rem;
    background-image: url("https://assets.ars.guide/renders/item/ars_nouveau/starbuncle_plush.png");
    background-repeat: no-repeat;
    background-position: 49% 64%;
    background-size: 185%;
    image-rendering: pixelated;
  }

  .starbuncle-petition-text {
    flex: 1;
    font-size: 0.875rem;
    line-height: 1.4;
  }

  .docs-banner-callout {
    margin-top: 1.5rem;
    overflow: hidden;
    text-align: center;
  }

  .docs-banner-link {
    display: block;
    text-decoration: none;
  }

  .docs-banner-link:hover {
    text-decoration: none;
  }

  .docs-banner {
    width: 100%;
  }

  .docs-banner-text {
    color: var(--bs-secondary-color, #6c757d);
    display: block;
    font-size: 0.875rem;
    padding-top: 0.25rem;
    padding-bottom: 0.25rem;
    background: #101929;
    border: 1px solid #cc7a1a;
    border-top: none;
  }

  .docs-title-bar {
    align-items: flex-start;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
  }

  .version-select {
    flex: 0 0 auto;
    margin-top: 0.75rem;
    max-width: 9rem;
  }

  .older-version-banner {
    margin: 0 0 1.5rem;
  }

  @media (max-width: 575.98px) {
    .docs-title-bar {
      display: block;
    }

    .version-select {
      margin-bottom: 1rem;
      margin-top: 0;
    }
  }

  .startup-scripts {
    color: #26b36c !important;
  }

  .client-scripts {
    color: #e67e23 !important;
  }

  .server-scripts {
    color: #b96ad9 !important;
  }

  table {
    margin: 1.5rem 0;
  }

  .footnotes hr {
    display: none;
  }
</style>
